MP3TAG_WEB_TAG=latest

# Set to false to build without Telegram Desktop
INCLUDE_TELEGRAM=true
# Set to false at runtime to prevent Telegram from launching
TELEGRAM_ENABLED=true

V_CONFIG_DIR=<path for mp3tag configs>
V_MUSIC_DIR=<path to music folder>
V_DOWNLOADS_DIR=<path for downloads (shared with Telegram)>
V_TELEGRAM_DATA=<path to persist Telegram session/settings>

PUID=1000
PGID=1000
